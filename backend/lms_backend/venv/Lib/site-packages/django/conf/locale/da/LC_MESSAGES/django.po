#, python-format
msgid ""
"вҖң%(value)sвҖқ value has an invalid date format. It must be in YYYY-MM-DD "
"format."
msgstr ""
"вҖң%(value)sвҖқ-vГҰrdien har et ugyldigt datoformat. Den skal vГҰre i formatet "
"Г…Г…Г…Г…-MM-DD."

#, python-format
msgid ""
"вҖң%(value)sвҖқ value has the correct format (YYYY-MM-DD) but it is an invalid "
"date."
msgstr ""
"вҖң%(value)sвҖқ-vГҰrdien har det korrekte format (Г…Г…Г…Г…-MM-DD) men er en ugyldig "
"dato."

msgid "Date (without time)"
msgstr "Dato (uden tid)"

#, python-format
msgid ""
"вҖң%(value)sвҖқ value has an invalid format. It must be in YYYY-MM-DD HH:MM[:ss[."
"uuuuuu]][TZ] format."
msgstr ""
"вҖң%(value)sвҖқ-vГҰrdien har et ugyldigt format. Den skal vГҰre i formatet Г…Г…Г…Г…-MM-"
"DD TT:MM[:ss[.uuuuuu]][TZ]."

#, python-format
msgid ""
"вҖң%(value)sвҖқ value has the correct format (YYYY-MM-DD HH:MM[:ss[.uuuuuu]]"
"[TZ]) but it is an invalid date/time."
msgstr ""
"вҖң%(value)sвҖқ-vГҰrdien har det korrekte format (Г…Г…Г…Г…-MM-DD TT:MM[:ss[.uuuuuu]]"
"[TZ]) men er en ugyldig dato/tid."

msgid "Date (with time)"
msgstr "Dato (med tid)"

